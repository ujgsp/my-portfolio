---
import { cn } from "../../../utils/styles";
import { cva, type VariantProps } from "class-variance-authority";

const alert = cva(
    "rounded-lg p-4 text-center border aria-[busy=true]:opacity-90",
    {
        variants: {
            intent: {
                success:
                    "border-green-400 bg-green-50 text-green-800 dark:bg-green-950 dark:text-green-200",
                error: "border-red-400 bg-red-50 text-red-700 dark:border-red-500/50 dark:bg-red-950/20 dark:text-red-300",
                info: "border-blue-400 bg-blue-50 text-blue-800 dark:bg-blue-950/30 dark:text-blue-200",
            },
        },
        defaultVariants: { intent: "success" },
    },
);

interface Props extends VariantProps<typeof alert> {
    title: string;
    id?: string;
    live?: "polite" | "assertive" | null;
    class?: string;
}

const {
    title,
    intent = "success",
    id = intent === "error" ? "form-error" : "form-status",
    live = intent === "error" ? "assertive" : "polite",
    class: cls,
} = Astro.props;

const role = live ? (intent === "error" ? "alert" : "status") : undefined;
const titleId = `${id}-title`;
---

<div
    id={id}
    role={role}
    aria-live={live ?? undefined}
    aria-atomic="true"
    aria-labelledby={titleId}
    tabindex="-1"
    class={cn(alert({ intent }), cls)}
>
    <h2 id={titleId} class="text-lg font-semibold md:text-xl">{title}</h2>
    <div class="mt-1">
        <slot />
    </div>
</div>
