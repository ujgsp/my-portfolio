---
import { cn } from "../../../utils/styles";
import type { HTMLAttributes } from "astro/types";
import { type FieldVariants, field } from "./styles";

interface Props extends HTMLAttributes<"textarea">, FieldVariants {
    name: string;
    placeholder?: string;
}

const { class: cls = "", intent, ...rest } = Astro.props;
---

<textarea {...rest} class={cn(field({ intent }), "resize-y", cls)}></textarea>
