---
import { cn } from "../../utils/styles";

interface Props {
    class?: string;
}

const { class: cls = "" } = Astro.props;
---

<span
    class={cn(
        "mb-4 inline-block rounded-md bg-green-100 px-4 py-2 text-sm font-medium text-green-800 dark:bg-green-900 dark:text-green-300",
        cls,
    )}
>
    Featured
</span>
