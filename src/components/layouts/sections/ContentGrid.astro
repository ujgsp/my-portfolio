---
import Card from "../../content/Card.astro";
import SectionHeader from "../../ui/SectionHeader.astro";
import { cn } from "../../../utils/styles";
import type { ContentEntry, WithMeta } from "../../../types";

interface Props {
    items: WithMeta<ContentEntry>[];
    class?: string;
    title?: string;
    href?: string;
    viewAllText?: string;
    eagerLoadCount?: number;
}

const {
    title,
    href,
    viewAllText,
    items,
    class: cls,
    eagerLoadCount = 0,
} = Astro.props;

if (!items || items.length === 0) return null;
---

<section>
    {title && href && <SectionHeader {title} {href} {viewAllText} />}

    <div
        class={cn(
            "grid grid-cols-1 gap-x-8 gap-y-10 sm:grid-cols-2 lg:grid-cols-3",
            cls,
        )}
    >
        {
            items.map((item, index) => (
                <Card
                    entry={item}
                    loading={index < eagerLoadCount ? "eager" : "lazy"}
                />
            ))
        }
    </div>
</section>
