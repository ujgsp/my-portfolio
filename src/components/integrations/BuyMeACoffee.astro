---
import BmcLogo from "../../assets/bmc-logo.svg";
import Button from "../ui/button/Button.astro";
import { cn } from "../../utils/styles";

interface Props {
    class?: string;
}

const { class: cls = "" } = Astro.props;
---

<Button
    href="https://www.buymeacoffee.com/truedaniyyel"
    class={cn("items-center gap-2", cls)}
>
    <BmcLogo class="bmc-logo size-6" />
    Fuel the next post</Button
>

<style>
    .bmc-logo {
        fill: currentColor;
    }

    .bmc-logo :global(.bmc-fill) {
        fill: #facc15;
    }

    :global(html.dark) .bmc-logo :global(.bmc-fill) {
        fill: #fff;
    }
</style>
